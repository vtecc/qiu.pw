{
  "env": {
    "NODE_ENV": "production"
  },
  "redirects": [
    {
      "source": "http://(.*)",
      "destination": "https://$1",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains; preload"
        }
      ]
    }
  ]
}